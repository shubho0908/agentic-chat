{
  "name": "agentic-chat",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "NODE_OPTIONS='--use-openssl-ca' next dev",
    "clean:next": "node scripts/clean-next.mjs",
    "build": "prisma generate && pnpm run clean:next && NODE_OPTIONS='--max-old-space-size=4096 --use-openssl-ca' next build",
    "start": "NODE_OPTIONS='--use-openssl-ca' next start",
    "lint": "eslint .",
    "doctor": "react-doctor . --verbose --diff",
    "typecheck": "next typegen && tsc --noEmit",
    "prisma:validate": "prisma validate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "test:audit": "node --import tsx --test tests/**/*.test.ts",
    "test:doc": "tsx scripts/test-doc-loader.ts",
    "test:mime": "tsx scripts/test-mime-detection.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@langchain/community": "^1.1.29",
    "@langchain/core": "^1.1.48",
    "@langchain/openai": "^1.4.7",
    "@langchain/textsplitters": "^1.0.1",
    "@mem0/vercel-ai-provider": "^2.0.5",
    "@mozilla/readability": "^0.6.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-pdf/renderer": "^4.5.1",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-query-devtools": "^5.100.14",
    "@tanstack/react-virtual": "^3.13.26",
    "@uploadthing/react": "^7.3.3",
    "better-auth": "^1.6.11",
    "canvas": "^3.2.3",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cohere-ai": "^8.0.0",
    "date-fns": "^4.3.0",
    "dompurify": "^3.4.7",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.40.0",
    "katex": "^0.17.0",
    "langsmith": "^0.7.3",
    "linkedom": "^0.18.12",
    "lucide-react": "^1.17.0",
    "mammoth": "^1.12.0",
    "mermaid": "^11.15.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "openai": "^6.39.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.21.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tiktoken": "^1.0.22",
    "undici": "8.3.0",
    "uploadthing": "^7.7.4",
    "vaul": "^1.1.2",
    "word-extractor": "^1.0.4",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@prisma/client": "^6.19.3",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/word-extractor": "^1.0.6",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.0",
    "eslint-config-next": "16.2.6",
    "husky": "^9.1.7",
    "postcss": "^8.5.15",
    "prisma": "^6.19.3",
    "react-doctor": "0.2.11",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@browserbasehq/stagehand": {
      "zod": "$zod",
      "openai": "$openai",
      "dotenv": "$dotenv"
    },
    "zod-to-json-schema": {
      "zod": "$zod"
    }
  },
  "knip": {
    "ignoreDependencies": [
      "dotenv"
    ]
  }
}
