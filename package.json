{
  "name": "agentic-chat",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "NODE_OPTIONS='--use-openssl-ca' next dev --turbopack",
    "clean:next": "node scripts/clean-next.mjs",
    "build": "prisma generate && pnpm run clean:next && NODE_OPTIONS='--max-old-space-size=4096 --use-openssl-ca' next build",
    "start": "NODE_OPTIONS='--use-openssl-ca' next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "prisma:validate": "prisma validate",
    "ci:local": "node scripts/ci-local.mjs",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "test:audit": "node --import tsx --test tests/**/*.test.ts",
    "test:doc": "tsx scripts/test-doc-loader.ts",
    "test:mime": "tsx scripts/test-mime-detection.ts"
  },
  "dependencies": {
    "@langchain/community": "^0.3.57",
    "@langchain/core": "^0.3.78",
    "@langchain/langgraph": "^0.4.9",
    "@langchain/openai": "^0.6.14",
    "@langchain/textsplitters": "^0.1.0",
    "@mem0/vercel-ai-provider": "^2.0.4",
    "@mozilla/readability": "^0.6.0",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-pdf/renderer": "^4.3.1",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-virtual": "^3.13.22",
    "@uploadthing/react": "^7.3.3",
    "better-auth": "^1.5.5",
    "canvas": "^3.2.0",
    "cheerio": "^1.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cohere-ai": "^7.20.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.36.0",
    "gaxios": "^7.1.4",
    "googleapis": "^171.4.0",
    "jose": "^6.2.1",
    "katex": "^0.16.38",
    "langsmith": "^0.3.78",
    "linkedom": "^0.18.12",
    "lucide-react": "^0.577.0",
    "mammoth": "^1.12.0",
    "mermaid": "^11.13.0",
    "next": "15.5.9",
    "next-themes": "^0.4.6",
    "openai": "^6.29.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.20.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tavily": "^1.0.2",
    "tiktoken": "^1.0.22",
    "undici": "7.16.0",
    "uploadthing": "^7.7.4",
    "vaul": "^1.1.2",
    "word-extractor": "^1.0.4",
    "xlsx": "^0.18.5",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/dompurify": "^3.2.0",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/word-extractor": "^1.0.6",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "postcss": "^8.5.8",
    "prisma": "^6.19.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  },
  "overrides": {
    "@browserbasehq/stagehand": {
      "zod": "$zod",
      "openai": "$openai",
      "dotenv": "$dotenv"
    },
    "zod-to-json-schema": {
      "zod": "$zod"
    }
  },
  "knip": {
    "ignoreDependencies": [
      "dotenv",
      "eslint-config-next"
    ]
  }
}
