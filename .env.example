# Encryption (REQUIRED)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-character-hex-encryption-key-here

# Mem0 (REQUIRED - for persistent AI memory)
# Get your API key from: https://app.mem0.ai/dashboard/api-keys
MEM0_API_KEY=m0-xxx

# pgvector / Embeddings (REQUIRED - for semantic caching and RAG)
# text-embedding-3-large supports up to 3072 dims (requires pgvector >= 0.7.0)
# text-embedding-3-small supports up to 1536 dims (any pgvector version)
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072
CACHE_TTL_SECONDS=3600

# Cohere Re-ranking (OPTIONAL - enhances RAG retrieval quality)
# Get your API key from: https://dashboard.cohere.com/api-keys
# If not set, falls back to standard vector search only
COHERE_API_KEY=your-cohere-api-key-here
RERANKER_MODEL=rerank-v3.5

# Database (PostgreSQL)
# For Neon: use the pooled URL for DATABASE_URL and the direct URL for DIRECT_DATABASE_URL
DATABASE_URL=postgresql://user:password@host-pooler.region.aws.neon.tech:5432/dbname?sslmode=require
DIRECT_DATABASE_URL=postgresql://user:password@host.region.aws.neon.tech:5432/dbname?sslmode=require

# Authentication (Better Auth)
# Generate secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-here
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (Get from: https://console.cloud.google.com/apis/credentials)
# Required for authentication and Gmail integration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# UploadThing (for file uploads)
UPLOADTHING_TOKEN=your-uploadthing-token

# Tavily Web Search (OPTIONAL - enables web search tool)
# Get your API key from: https://tavily.com/
# If not set, web search tool will be disabled
TAVILY_API_KEY=your-tavily-api-key-here
